
<?php

if (php_sapi_name() !== 'cli') {
    exit("This command can only be run from the CLI.\n");
}

$command = $argv[1] ?? null;

switch ($command) {
    case 'start':
        echo "Starting Orion Development Server...\n";

        $host = '127.0.0.1';
        $port = '8000';

        passthru("php -S {$host}:{$port} index.php");
        break;
    case 'queue':
        echo "Starting Orion Queue Worker...\n";
        passthru("php core/commands/queue_worker.php");
        break;
    case 'create:controller':
        echo "Creating Orion Controller...\n";
        passthru("php core/commands/controller_creator.php " . $argv[2]);
        break;
    case 'create:schema':
        echo "Creating Orion Table...\n";
        passthru("php core/commands/table_creator.php " . $argv[2] . " " . 'create');
        break;
    case 'generate:tables':
        echo "Running Orion Migrations...\n";
        passthru("php core/commands/db_migrator.php");
        break;
    default:
        echo "Orion Framework CLI\n";
        echo "Available commands:\n";
        echo "  start\n";
        echo "  queue\n";
        echo "  create:controller <controller_name>\n";
        echo "  create:schema <schema_name> <action>\n";
        echo "  generate:tables\n";
        break;
}
