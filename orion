
<?php

if (php_sapi_name() !== 'cli') {
    exit("This command can only be run from the CLI.\n");
}

$command = $argv[1] ?? null;

switch ($command) {
    case 'start':
        echo "Starting Orion Development Server...\n";

        $host = '127.0.0.1';
        $port = '8000';

        passthru("php -S {$host}:{$port} index.php");
        break;

    default:
        echo "Orion Framework CLI\n";
        echo "Available commands:\n";
        echo "  serve\n";
        break;
}
